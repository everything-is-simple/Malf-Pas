{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Malf-Pas/plugins/malf-pas-workflow/scripts/malf_pas_codex_hook.ps1 -Event SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Malf-Pas/plugins/malf-pas-workflow/scripts/malf_pas_codex_hook.ps1 -Event UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "shell_command|apply_patch|codebase_retrieval|sequentialthinking",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Malf-Pas/plugins/malf-pas-workflow/scripts/malf_pas_codex_hook.ps1 -Event PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "shell_command|apply_patch|codebase_retrieval|sequentialthinking",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Malf-Pas/plugins/malf-pas-workflow/scripts/malf_pas_codex_hook.ps1 -Event PostToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File H:/Malf-Pas/plugins/malf-pas-workflow/scripts/malf_pas_codex_hook.ps1 -Event Stop"
          }
        ]
      }
    ]
  }
}
